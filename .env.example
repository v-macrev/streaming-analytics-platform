# ============================================================
# Streaming Analytics Platform
# Environment Template
# Copy this file to .env and adjust values as needed.
# ============================================================

# ------------------------------------------------------------
# Project / Environment
# ------------------------------------------------------------
APP_ENV=local
APP_NAME=streaming-analytics-platform
APP_LOG_LEVEL=INFO
APP_TIMEZONE=UTC

# ------------------------------------------------------------
# Kafka
# ------------------------------------------------------------
KAFKA_TOPIC_EVENTS=events.raw
KAFKA_BOOTSTRAP_SERVERS_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:9094
KAFKA_CONSUMER_GROUP=streaming-analytics-consumer
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_OFFSET_RESET=latest

# ------------------------------------------------------------
# Producer
# ------------------------------------------------------------
PRODUCER_SOURCE_NAME=web-simulator
PRODUCER_EVENT_INTERVAL_MS=500
PRODUCER_BATCH_SIZE=1
PRODUCER_USER_ID_MIN=1000
PRODUCER_USER_ID_MAX=9999
PRODUCER_SESSION_ID_PREFIX=sess
PRODUCER_ORDER_ID_PREFIX=ord
PRODUCER_PAYMENT_ID_PREFIX=pay
PRODUCER_INVENTORY_WAREHOUSE_COUNT=3
PRODUCER_CURRENCY=BRL

# Relative generation weight by event type.
# These values are documentation-friendly and may later be
# parsed by the producer config layer.
PRODUCER_WEIGHT_PAGE_VIEW=45
PRODUCER_WEIGHT_ADD_TO_CART=20
PRODUCER_WEIGHT_ORDER_CREATED=12
PRODUCER_WEIGHT_PAYMENT_PROCESSED=13
PRODUCER_WEIGHT_INVENTORY_UPDATED=10

# ------------------------------------------------------------
# Spark / Streaming
# ------------------------------------------------------------
SPARK_APP_NAME=streaming-analytics-job
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints
SPARK_TRIGGER_INTERVAL=10 seconds
STREAM_WATERMARK_DELAY=2 minutes
STREAM_WINDOW_DURATION=1 minute
STREAM_SLIDE_DURATION=1 minute

# ------------------------------------------------------------
# ClickHouse
# ------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_USER=analytics_user
CLICKHOUSE_PASSWORD=analytics_pass
CLICKHOUSE_METRICS_TABLE=metrics_realtime_1m

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ------------------------------------------------------------
# Kafka UI
# ------------------------------------------------------------
KAFKA_UI_PORT=8080

# ------------------------------------------------------------
# Spark UI / Cluster
# ------------------------------------------------------------
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8081
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2G

# ------------------------------------------------------------
# ClickHouse Ports
# ------------------------------------------------------------
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# ------------------------------------------------------------
# Kafka Ports
# ------------------------------------------------------------
KAFKA_INTERNAL_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_EXTERNAL_PORT=9094

# ------------------------------------------------------------
# Future Kubernetes Extension
# These variables are kept generic on purpose so the same
# names can later map to ConfigMaps and Secrets.
# ------------------------------------------------------------
K8S_NAMESPACE=streaming-analytics
K8S_APP_LABEL=streaming-analytics-platform